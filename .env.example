# Basic Workbench Configuration
# Copy to .env and adjust as needed.

# Server port (default: 9000)
WORKBENCH_PORT=9000

# Bind address (default: 127.0.0.1 — localhost only)
# Set to 0.0.0.0 to allow external access (not recommended without auth)
WORKBENCH_HOST=127.0.0.1

# SQLite database path (default: ./workbench.db)
WORKBENCH_DB_PATH=./workbench.db

# Set to 1 to auto-create demo agents on startup (for testing)
WB_SEED_DEMO=0
